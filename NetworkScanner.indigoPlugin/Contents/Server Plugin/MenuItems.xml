<?xml version="1.0" encoding="UTF-8"?>
<MenuItems>

	<MenuItem id="forceRescan">
		<Name>Force Immediate Rescan</Name>
		<CallbackMethod>forceRescan</CallbackMethod>
	</MenuItem>

	<MenuItem id="pingCustomHost">
		<Name>Ping a Device (IP or DNS ...</Name>
		<ConfigUI>
			<Field id="host" type="textfield" defaultValue="">
				<Label>IP address or hostname</Label>
			</Field>

			<Field id="hostLabel" type="label" alignWithControl="true" fontSize="small" fontColor="darkgrey">
				<Label>Enter an IP address (e.g. 192.168.1.1) or a DNS name (e.g. google.com).
Result is written to the log and to variable networkScanner_pingDevice (on / off).</Label>
			</Field>

			<Field id="execPing" type="button">
				<Label> </Label>
				<Title>PING</Title>
				<CallbackMethod>pingCustomHostButton</CallbackMethod>
			</Field>

			<Field id="result" type="textfield">
				<Label>result</Label>
			</Field>

		</ConfigUI>
	</MenuItem>

	<MenuItem id="addDefaultExtDevices">
		<Name>Add Internet Ping Devices ...</Name>
		<ConfigUI>
			<Field id="introLabel0" type="label" fontSize="small"  fontColor="darkgrey">
				<Label>This is for convenience, can all be done manually
				</Label>
			</Field>

			<Field id="internetPingdesp" type="label" fontColor="orange">
				<Label>── Internet Ping Devices ────────────────────</Label>
			</Field>

			<Field id="introLabel1" type="label">
				<Label>Select 3 providers.
 "Ping-"name devices will be created.
   they show up / down and ms response time
 A device "Ping-NetworkScanner Internet" will be created that reflects internet down / up = all three down / one up </Label>
			</Field>
			<Field id="introLabel2" type="label" fontSize="small"  fontColor="darkgrey">
				<Label>This could also be created manually</Label>
			</Field>

			<Field id="extDev_google" type="checkbox" defaultValue="false">
				<Label>ping-google  (www.google.com)</Label>
			</Field>

			<Field id="extDev_yahoo" type="checkbox" defaultValue="false">
				<Label>ping-yahoo  (www.yahoo.com)</Label>
			</Field>

			<Field id="extDev_microsoft" type="checkbox" defaultValue="false">
				<Label>ping-microsoft  (www.microsoft.com)</Label>
			</Field>

			<Field id="extDev_cnn" type="checkbox" defaultValue="false">
				<Label>ping-cnn  (www.cnn.com)</Label>
			</Field>

			<Field id="extDev_siemens" type="checkbox" defaultValue="false">
				<Label>ping-siemens  (www.siemens.de</Label>
			</Field>

			<Field id="extDev_sap" type="checkbox" defaultValue="false">
				<Label>ping-sap  (www.sap.de)</Label>
			</Field>

			<Field id="extDev_indigodomo" type="checkbox" defaultValue="false">
				<Label>ping-indigodomo  (www.indigodomo.com)</Label>
			</Field>

			<Field id="customHostSeparator" type="label" fontSize="small" fontColor="darkgrey">
				<Label>── Custom host ──────────────────────────────</Label>
			</Field>

			<Field id="customHost" type="textfield" defaultValue="">
				<Label>Hostname or IP (e.g. www.welt.de)</Label>
			</Field>

			<Field id="customHostLabel" type="label" alignWithControl="true" fontSize="small" fontColor="darkgrey">
				<Label>Leave blank to skip. Device name will be "Ping-{hostname}".</Label>
			</Field>

			<Field id="addDefaultExtDevices" type="button">
				<Label> </Label>
				<Title>Add Selected Ping Devices</Title>
				<CallbackMethod>addDefaultExternalDevices</CallbackMethod>
			</Field>

			<Field id="extDevMsg" type="label" alignWithControl="true" fontSize="small" fontColor="green">
				<Label>Check providers above then click the button. Placed in the Device Folder. Safe to click multiple times — skips any host that already exists.</Label>
			</Field>

			<Field id="extDevManualNote" type="label" fontSize="small" fontColor="darkgrey">
				<Label>External devices can also be created manually via New Device → External Device.</Label>
			</Field>

			<Field id="internetAddrSep" type="label" fontColor="orange">
				<Label>── Internet Address Device ────────────────────</Label>
			</Field>

			<Field id="internetAddrInfo" type="label" fontSize="small" fontColor="darkgrey">
				<Label>Monitors the public (WAN) IP of this machine. Fetches from api.ipify.org, checkip.amazonaws.com, icanhazip.com in order. Safe to click multiple times — skips if already exists.
	This could also be created manually</Label>
			</Field>

			<Field id="addInternetAddrBtn" type="button">
				<Label>Add Internet Address device</Label>
				<Title>ADD</Title>
				<CallbackMethod>addInternetAddressDevice</CallbackMethod>
			</Field>
		
			<Field id="internetAddrMsg" type="label" alignWithControl="true" fontSize="small" fontColor="green">
				<Label> </Label>
			</Field>

		</ConfigUI>
	</MenuItem>

	<MenuItem id="performBroadPortScan">
		<Name>Perform Broad Port Scan on All Online Devices ...</Name>
		<CallbackMethod>performBroadPortScan</CallbackMethod>
	</MenuItem>

	<MenuItem id="setDevState">
		<Name>Set a State of Device…</Name>
		<ConfigUI>
			<Field id="MSG" type="label" defaultValue="">
				<Label> </Label>
			</Field>

			<Field id="devId" type="menu" defaultValue="0">
				<Label>Select device:</Label>
				<List class="self" filter="all" method="filterNetworkAllDevices" dynamicReload="true"/>
			</Field>

			<Field id="refreshCallbackMethod" type="textfield" defaultValue="dynamicCallbackSetDeviceID" hidden="true"/>
			<Field id="stateName" type="menu">
				<Label>Select state to overwrite:</Label>
				<List class="self" filter="" method="selectState" dynamicReload="true"/>
			</Field>

			<Field id="oldValue" type="textfield" readonly="true">
				<Label>Current value:</Label>
			</Field>

			<Field id="newValue" type="textfield">
				<Label>New value:</Label>
			</Field>

			<Field id="newValueUi" type="textfield">
				<Label>New UI value (leave blank to ignore):</Label>
			</Field>

			<Field id="executeOverwrite" type="button">
				<Label> </Label>
				<Title>OVERWRITE</Title>
				<CallbackMethod>executeOverwriteButtonState</CallbackMethod>
			</Field>

		</ConfigUI>
	</MenuItem>


	<MenuItem id="manageIgnoredMacs">
		<Name>Manage Ignored MAC Addresses ...</Name>
		<ConfigUI>
			<Field id="availableDevicesList" type="list" rows="8">
				<Label>Discovered Devices  (click to select)</Label>
				<List class="self" filter="available" method="getNetworkDeviceList" dynamicReload="true"/>
			</Field>

			<Field id="addToIgnoredButton" type="button">
				<Label> </Label>
				<Title>▼  Ignore Selected Device</Title>
				<CallbackMethod>addToIgnored</CallbackMethod>
			</Field>

			<Field id="ignoredDevicesList" type="list" rows="5">
				<Label>Ignored Devices  (click to select)</Label>
				<List class="self" filter="ignored" method="getIgnoredDeviceList" dynamicReload="true"/>
			</Field>

			<Field id="removeFromIgnoredButton" type="button">
				<Label> </Label>
				<Title>▲  Un-ignore Selected Device</Title>
				<CallbackMethod>removeFromIgnored</CallbackMethod>
			</Field>

		</ConfigUI>
	</MenuItem>


	<MenuItem id="printReports">
		<Name>Print tools ...</Name>
		<ConfigUI>

			<Field id="sec1" type="label" fontColor="orange">
				<Label>── Device Lists ─────────────────</Label>
			</Field>

			<Field id="btnAllDevices" type="button">
				<Label>All discovered devices</Label>
				<Title>PRINT</Title>
				<CallbackMethod>listKnownDevices</CallbackMethod>
			</Field>

			<Field id="btnByState" type="button">
				<Label>Devices grouped by OS / ports / type</Label>
				<Title>PRINT</Title>
				<CallbackMethod>listDevicesByState</CallbackMethod>
			</Field>

			<Field id="btnIpChanged" type="button">
				<Label>Devices with IP address changes</Label>
				<Title>PRINT</Title>
				<CallbackMethod>printIpChangedDevices</CallbackMethod>
			</Field>

			<Field id="btnEmptyStates" type="button">
				<Label>Empty states across all devices = not used</Label>
				<Title>PRINT</Title>
				<CallbackMethod>listEmptyStates</CallbackMethod>
			</Field>

			<Field id="sec2" type="label" fontColor="orange">
				<Label>── Instability Report ──────────────</Label>
			</Field>

			<Field id="cutoff" type="menu" defaultValue="300">
				<Label>Max time between on/off flips</Label>
				<List>
					<Option value="60">1 minute</Option>
					<Option value="120">2 minutes</Option>
					<Option value="180">3 minutes</Option>
					<Option value="240">4 minutes</Option>
					<Option value="300">5 minutes</Option>
					<Option value="360">6 minutes</Option>
					<Option value="420">7 minutes</Option>
					<Option value="480">8 minutes</Option>
				</List>
			</Field>

			<Field id="btnInstable" type="button" alignWithControl="true">
				<Label> </Label>
				<Title>PRINT</Title>
				<CallbackMethod>printInstableDevices</CallbackMethod>
			</Field>

			<Field id="sec3" type="label" fontColor="orange">
				<Label>── Seen-Interval Statistics ────────────</Label>
			</Field>

			<Field id="sortOrder" type="menu" defaultValue="ip">
				<Label>Sort by</Label>
				<List>
					<Option value="ip">IP address</Option>
					<Option value="name">Device name</Option>
					<Option value="lastseen">Last seen</Option>
				</List>
			</Field>

			<Field id="btnSeenStats" type="button" alignWithControl="true">
				<Label> </Label>
				<Title>PRINT</Title>
				<CallbackMethod>printSeenStats</CallbackMethod>
			</Field>

			<Field id="btnResetStats" type="button">
				<Label>Reset seen-interval counters</Label>
				<Title>RESET</Title>
				<CallbackMethod>resetSeenStats</CallbackMethod>
			</Field>

		</ConfigUI>
	</MenuItem>

	<MenuItem id="trackDeviceLogging">
		<Name>Track Device / Logging Tools ...</Name>
		<ConfigUI>

			<Field id="trackSep" type="label" fontColor="orange">
				<Label>── Track Specific Device ────────────────────</Label>
			</Field>

			<Field id="debugTrackedDevice" type="textfield">
				<Label>Track Device (MAC or IP)</Label>
			</Field>

			<Field id="debugTrackedDeviceLabel" type="label" alignWithControl="true" fontSize="small" fontColor="green">
				<Label>One or more MACs / IPs, comma-separated  (e.g.  aa:bb:cc:dd:ee:ff, 192.168.1.5). Logs every raw tcpdump line, ARP entry, ping probe and state change for all listed devices to plugin.log. No Save needed — use the buttons below.</Label>
			</Field>

			<Field id="activateTrackingBtn" type="button">
				<Label> </Label>
				<Title>▶ Activate Tracking Now</Title>
				<CallbackMethod>activateDeviceTracking</CallbackMethod>
			</Field>

			<Field id="stopTrackingBtn" type="button" alignWithControl="true">
				<Label> </Label>
				<Title>■ Stop Tracking</Title>
				<CallbackMethod>stopDeviceTracking</CallbackMethod>
			</Field>

			<Field id="trackingActivateMsg" type="textfield" readonly="true" defaultValue="— enter MAC or IP above, then click ▶ Activate —">
				<Label>Status</Label>
			</Field>

			<Field id="logToolsSep" type="label" fontColor="orange">
				<Label>── Per-Device Logging ───────────────────────</Label>
			</Field>

			<Field id="turnOffDeviceLogging" type="button">
				<Label>Turn off all per-device logging</Label>
				<Title>TURN OFF</Title>
				<CallbackMethod>turnOffAllDeviceLogging</CallbackMethod>
			</Field>

			<Field id="deviceLogMsg" type="textfield" readonly="true" defaultValue="">
				<Label>Status</Label>
			</Field>

		</ConfigUI>
	</MenuItem>

	<MenuItem id="helpPlugin">
		<Name>Help print to log </Name>
		<CallbackMethod>helpPlugin</CallbackMethod>
	</MenuItem>
	
	<MenuItem id="slowPortScan">
		<Name>Slow Port Scan (0–1000) on One Device ...</Name>
		<ConfigUI>
			<Field id="slowScanWarning" type="label" fontColor="orange">
				<Label>Probes all 1 001 TCP ports (0–1 000) on one device at ≤ 2 ports/second.
Runs in the background — takes approximately 8 to 17 minutes.
Results and progress are printed to the Indigo log.</Label>
			</Field>

			<Field id="devId" type="menu" defaultValue="0">
				<Label>Select device:</Label>
				<List class="self" filter="all" method="filterNetworkAllDevices" dynamicReload="true"/>
			</Field>

			<Field id="startSlowScan" type="button">
				<Label> </Label>
				<Title>▶ START SLOW SCAN</Title>
				<CallbackMethod>startSlowPortScan</CallbackMethod>
			</Field>

			<Field id="slowScanMsg" type="textfield" readonly="true" defaultValue="— select a device, then click ▶ START SLOW SCAN —">
				<Label>Status</Label>
			</Field>
		</ConfigUI>
	</MenuItem>

	<MenuItem id="importFromFingscan">
		<Name>Fingscan Migration Tools...</Name>
		<ConfigUI>
			<Field id="MSG" type="textfield" defaultValue="">
				<Label>msgfrom plugin: </Label>
			</Field>

			<Field id="Lab0" type="label" defaultValue="">
				<Label>(0) compare fingscan and network scanner devices </Label>
			</Field>

			<Field id="executeCompare" type="button">
				<Title>PRINT</Title>
				<CallbackMethod>compareFingscanToNetworkScannerDevices</CallbackMethod>
			</Field>

			<Field id="Lab1" type="label" defaultValue="">
				<Label>(1) All devices found with matching MAC number will get a state: fingscanDeviceName = old fingscan name, ping settings </Label>
			</Field>

			<Field id="executeImport" type="button">
				<Title>IMPORT</Title>
				<CallbackMethod>importNamesFromFingscan</CallbackMethod>
			</Field>

			<Field id="Lab2" type="label" defaultValue="">
				<Label>(2) All devices found with matching MAC number will get a new name: oldfing_scan_name-prefix </Label>
			</Field>

			<Field id="executeOverwrite" type="button">
				<Title>OVERWRITE</Title>
				<CallbackMethod>overwriteDevNamesWithFingNames</CallbackMethod>
			</Field>

			<Field id="Lab3" type="label" defaultValue="">
				<Label>(3) Copy Fingscan devices not yet in NetworkScanner — created as oldfingName-net-ping-only, DISABLED. Enable each one manually to start monitoring.</Label>
			</Field>

			<Field id="executeCopyFingscanOnly" type="button">
				<Title>COPY NEW</Title>
				<CallbackMethod>copyFingscanOnlyToNetworkScanner</CallbackMethod>
			</Field>

		</ConfigUI>
	</MenuItem>

</MenuItems>
