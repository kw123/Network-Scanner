<?xml version="1.0" encoding="UTF-8"?>
<Actions>

	<!-- Ping any IP / DNS name and update networkScanner_pingDevice variable -->
	<Action id="pingCustomHostAction">
		<Name>Ping Address</Name>
		<CallbackMethod>pingCustomHostAction</CallbackMethod>
		<ConfigUI>
			<Field id="host" type="textfield" defaultValue="">
				<Label>IP address or hostname</Label>
			</Field>
			<Field id="hostLabel" type="label" alignWithControl="true" fontSize="small" fontColor="darkgrey">
				<Label>Enter an IP address or DNS name to ping. Result is logged and written to variable networkScanner_pingDevice (on / off).</Label>
			</Field>
		</ConfigUI>
	</Action>

</Actions>
